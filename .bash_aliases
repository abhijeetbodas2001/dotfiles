# Open files
alias of=xdg-open

alias diff="diff --color=always"

# For journaling
alias j='nvim ~/textfiles/journal/$(date +%F)'

# Use the maintained version from https://ctags.io/
alias ctags='ctags-universal'

# Interactive `rm`
alias del='rm -i'

# Use visual mode
alias mkdir='mkdir -v'

alias less='less -R'

alias suu='sudo apt update && sudo apt upgrade && sudo apt autoremove && sudo apt autoclean'

alias vim='nvim'
alias n='nvim'

alias jdate='echo "date: $(date "+%F %T") +5:30"'
